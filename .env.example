# ===== Free API keys =====
# Groq (STT + optional LLM):   https://console.groq.com/keys
# Cerebras (optional LLM):     https://cloud.cerebras.ai/
GROQ_API_KEY=
CEREBRAS_API_KEY=

# ===== LLM provider: "groq" or "cerebras" =====
LLM_PROVIDER=groq
GROQ_MODEL=llama-3.3-70b-versatile
CEREBRAS_MODEL=llama-3.3-70b

# ===== STT (always Groq Whisper) =====
STT_MODEL=whisper-large-v3-turbo

# ===== TTS (edge-tts, free) =====
# Kid-friendly voices: en-US-AnaNeural (child), en-US-JennyNeural, en-GB-MaisieNeural (child)
TTS_VOICE=en-US-AnaNeural

# ===== VAD / endpointing (tune for latency vs. patience) =====
VAD_THRESHOLD=0.5
VAD_MIN_SILENCE_MS=600
VAD_SPEECH_PAD_MS=100

# ===== RAG =====
CHROMA_PATH=./data/chroma
